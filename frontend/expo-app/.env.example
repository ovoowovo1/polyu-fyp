# Android emulator:
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3000

# Android/iOS physical device on the same Wi-Fi as the backend computer:
# EXPO_PUBLIC_API_BASE_URL=http://<your-lan-ip>:3000

# If you run Expo for web, add its dev origin to backend CORS_ORIGINS, for example:
# CORS_ORIGINS=["http://localhost:5173","http://localhost:8081","http://127.0.0.1:8081"]
