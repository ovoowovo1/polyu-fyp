# Required runtime configuration
PG_DSN=postgresql://postgres:password@localhost:5432/postgres
JWT_SECRET_KEY=change-me
GOOGLE_API_KEY_LIST=your-google-api-key-1,your-google-api-key-2
OPENAI_EMBEDDING_API_KEY=your-openai-compatible-embedding-key

# Optional settings with current application defaults
PORT=3000
GOOGLE_AI_MODEL=google/gemini-3-flash-preview
GOOGLE_AI_EMBEDDINGS=gemini-embedding-001
GOOGLE_TTS_MODEL=gemini-2.5-flash-preview-tts
OPENAI_EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
OPENAI_EMBEDDING_MODEL=google/gemini-embedding-001
OPENAI_EMBEDDING_ACTIVE_COLUMN=embedding
OPENAI_EMBEDDING_FALLBACK_MODEL=google/gemini-embedding-2-preview
OPENAI_EMBEDDING_FALLBACK_COLUMN=embedding_v2

# Optional dev-only credentials for manual smoke scripts and evaluation utilities.
# Never hardcode live provider keys in backend test or evaluation files.
GENAI_API_KEY=
GENAI_BASE_URL=
EVAL_LLM_API_KEY=
EVAL_LLM_BASE_URL=https://www.chataiapi.com/v1
EVAL_LLM_MODEL=gemini-2.5-flash
EVAL_EMBEDDING_API_KEY=
EVAL_EMBEDDING_BASE_URL=
EVAL_EMBEDDING_MODEL=
