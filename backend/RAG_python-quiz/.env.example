# Required runtime configuration
PG_DSN=postgresql://postgres:password@localhost:5432/postgres
JWT_SECRET_KEY=change-me
LLM_API_KEYS=your-llm-api-key-1,your-llm-api-key-2

# Optional settings with current application defaults
PORT=3000
LLM_MODEL=google/gemini-3-flash-preview
GOOGLE_TTS_MODEL=gemini-2.5-flash-preview-tts
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_MODEL=google/gemini-embedding-001
EMBEDDING_ACTIVE_COLUMN=embedding
EMBEDDING_FALLBACK_MODEL=google/gemini-embedding-2-preview
EMBEDDING_FALLBACK_COLUMN=embedding_v2

# Optional dev-only credentials for manual smoke scripts and evaluation utilities.
# Never hardcode live provider keys in backend test or evaluation files.
LLM_API_KEY=
EMBEDDING_API_KEY=
LLM_BASE_URL=
EVAL_LLM_API_KEY=
EVAL_LLM_BASE_URL=https://www.chataiapi.com/v1
EVAL_LLM_MODEL=gemini-2.5-flash
EVAL_EMBEDDING_API_KEY=
EVAL_EMBEDDING_BASE_URL=
EVAL_EMBEDDING_MODEL=
